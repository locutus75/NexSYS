{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NexSYS",
  "version": "0.1.6",
  "identifier": "com.nexsys.wallet",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NexSYS — Syscoin Command Center",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/locutus75/NexSYS/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIxMkNFNkZEMjYyQTJEQgpSV1Rib21MU2I4NFNDNlNGSGNJMFlhRDk5OVJ4TXBmanZhbHhwdi9Zejc0M3l4MFZkSnNCcHhGUQo="
    }
  }
}
